{
  "name": "agentcom",
  "private": true,
  "keywords": [
    "pi-package"
  ],
  "type": "module",
  "pi": {
    "extensions": [
      "./packages/pi-agentcom/src/index.ts"
    ]
  },
  "workspaces": [
    "packages/*",
    "server/*"
  ],
  "scripts": {
    "test": "vitest run && vitest run --config vitest.node.config.ts",
    "test:worker": "vitest run",
    "test:client": "vitest run --config vitest.node.config.ts",
    "typecheck": "tsc -b",
    "publish:packages": "node scripts/publish-agentcom-packages.mjs",
    "publish:packages:dry-run": "node scripts/publish-agentcom-packages.mjs --dry-run",
    "test:integration:real": "node scripts/agentcom-real-integration.mjs",
    "test:pi-extension": "node scripts/agentcom-pi-extension-smoke.mjs"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.13",
    "@cloudflare/workers-types": "^4.20260605.1",
    "@types/node": "^25.9.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8",
    "wrangler": "^4.98.0"
  }
}
